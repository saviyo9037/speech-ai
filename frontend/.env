# ==========================================
# Nova Voice OS — Frontend Environment Config
# ==========================================

# Set to 'true' to use Sarvam AI for STT + TTS.
# Set to 'false' to use the original Browser Web Speech API.
VITE_USE_SARVAM=true

# Backend URL where Sarvam proxy routes are hosted
VITE_SARVAM_BACKEND_URL=http://localhost:5000

# Language code used for Sarvam requests from the frontend
# Options: en-IN, hi-IN, bn-IN, kn-IN, ml-IN, mr-IN, ta-IN, te-IN, gu-IN
VITE_SARVAM_LANGUAGE=en-IN

# Speaker voice for TTS
# Options: meera, pavithra, maitreyi, arvind, amol, amartya, diya, neel, misha, vian, arjun, maya
VITE_SARVAM_SPEAKER=meera
